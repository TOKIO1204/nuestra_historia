# ─────────────────────────────────────────────────────────
# Vercel Blob  →  Dashboard → Storage → Create Blob Store
# ─────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# Vercel Postgres  →  Dashboard → Storage → Create Database
# (Vercel las agrega automáticamente al conectar el proyecto)
# ─────────────────────────────────────────────────────────
POSTGRES_URL=postgres://default:password@host:5432/verceldb
POSTGRES_URL_NON_POOLING=postgres://default:password@host:5432/verceldb
POSTGRES_USER=default
POSTGRES_HOST=host
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=verceldb

# ─────────────────────────────────────────────────────────
# PIN para el modal de administrador  (solo tú lo sabes)
# ─────────────────────────────────────────────────────────
VITE_ADMIN_PIN=tu_pin_secreto
